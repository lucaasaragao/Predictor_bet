# Copie este arquivo para .env e preencha com seu token real
FOOTBALL_DATA_TOKEN=
ODDS_API_KEY=
ODDS_REGIONS=eu
# Opcional: lista de bookmakers separados por virgula. Se preencher, tem prioridade sobre regions.
# Exemplo focado em futebol (EU): pinnacle,betfair_ex_eu,betsson,williamhill
ODDS_BOOKMAKERS=
ODDS_MIN_EV=0.03
ODDS_MIN_EDGE_GATE=0.10
ODDS_ONLY_VALUE_GAMES=true
ODDS_MAX_SPORT_CALLS=3
ODDS_USE_UPCOMING=true
ODDS_DEBUG_VISUAL=false
